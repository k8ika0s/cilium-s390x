## We split tests into two parts: one that can be run in parallel
## and tests that cannot be run in parallel with other packages
## One drawback of this approach is that
## if first set of tests fails, second one is not run
{ PRIVILEGED_TESTS=true PATH=/root/.cargo/bin:/root/.local/bin:/root/bin:/usr/share/Modules/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/root/work/cilium-s390x/bpf CGO_ENABLED=0 go test -mod=vendor -vet=all -tags=osusergo -ldflags "-X github.com/cilium/cilium/pkg/kvstore.etcdDummyAddress=http://etcd:4002" \
	./... -timeout 720s -run "TestPrivileged.*" -covermode=count -coverprofile=coverage.out \
&& PRIVILEGED_TESTS=true PATH=/root/.cargo/bin:/root/.local/bin:/root/bin:/usr/share/Modules/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/root/work/cilium-s390x/bpf CGO_ENABLED=0 go test -mod=vendor -vet=all -tags=osusergo -ldflags "-X github.com/cilium/cilium/pkg/kvstore.etcdDummyAddress=http://etcd:4002" \
	./pkg/datapath/linux/... ./pkg/datapath/loader/... ./pkg/datapath/neighbor/test/... -timeout 720s -run "TestPrivileged.*" \
	-json -covermode=count -coverprofile=coverage2.out -p 1 --tags=unparallel; } | cat
